DEPLOY_BRANCH=master
DEPLOY_EVENT=push
DEPLOY_SCRIPT=/opt/website/app/deploy/deploy.sh
DEPLOY_WEBHOOK_HOST=127.0.0.1
DEPLOY_WEBHOOK_PORT=9000
DEPLOY_WEBHOOK_SECRET=replace-with-a-long-random-secret

REPO_DIR=/opt/website/app
IMAGE_NAME=website-app
CONTAINER_NAME=website-app
APP_PORT=3000
CONTAINER_PORT=3000
HEALTH_PATH=/
LOG_FILE=/opt/website/deploy.log
